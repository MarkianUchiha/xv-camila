---
// Sección Regalos: sobre con dinero y link a mesa de regalos Liverpool
---

<section id="gifts" class="py-20 md:py-28 px-6" style="background-color: #F0F8FF;">
	<div class="max-w-md mx-auto text-center reveal">
		<!-- Ícono regalo -->
		<svg class="w-10 h-10 mx-auto text-gold-500 mb-5" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
			<rect x="3" y="8" width="18" height="13" rx="2" stroke="currentColor" stroke-width="1.5"/>
			<path d="M12 8v13" stroke="currentColor" stroke-width="1.5"/>
			<path d="M3 12h18" stroke="currentColor" stroke-width="1.5"/>
			<path d="M12 8c-1-2-4-4-5-3s1 3 5 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
			<path d="M12 8c1-2 4-4 5-3s-1 3-5 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
		</svg>

		<h2 class="font-serif text-3xl md:text-4xl text-primary-800 mb-4">
			Regalos
		</h2>
		<p class="font-sans text-sm text-primary-600/80 mb-8">
			Tu presencia es mi mayor regalo, pero si deseas tener un detalle conmigo:
		</p>

		<!-- Sobre con dinero -->
		<div class="glass-strong p-6 mb-6 inline-flex items-center gap-3">
			<svg class="w-8 h-8 text-gold-500 flex-shrink-0" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
				<rect x="2" y="5" width="20" height="14" rx="2" stroke="currentColor" stroke-width="1.5"/>
				<path d="M2 5l10 7 10-7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
			</svg>
			<span class="font-display text-xs tracking-[0.2em] text-primary-800 uppercase">
				Sobre con Dinero
			</span>
		</div>

		<br/>

		<!-- Botón mesa de regalos -->
		<a
			href="https://mesaderegalos.liverpool.com.mx/milistaderegalos/51971590"
			target="_blank"
			rel="noopener noreferrer"
			class="inline-block mt-4 px-8 py-3 rounded-full font-display text-xs tracking-widest uppercase text-white transition-all duration-300 hover:scale-105 hover:shadow-lg"
			style="background: linear-gradient(135deg, #D4AF37, #B8860B);"
		>
			Ver Mesa de Regalos en Liverpool
		</a>
	</div>
</section>
