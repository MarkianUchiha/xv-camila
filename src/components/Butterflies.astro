---
// Mariposas flotantes decorativas con animación CSS
// Se renderizan como SVGs posicionados absolutos dentro del contenedor padre

// Configuración de cada mariposa: posición, tamaño, color, delay y duración
const butterflies = [
	{ left: '8%',  top: '15%', size: 28, color: '#D4AF37', delay: '0s',   duration: '18s', opacity: 0.5 },
	{ left: '85%', top: '20%', size: 35, color: '#87CEEB', delay: '3s',   duration: '22s', opacity: 0.4 },
	{ left: '15%', top: '60%', size: 22, color: '#87CEEB', delay: '7s',   duration: '20s', opacity: 0.35 },
	{ left: '75%', top: '70%', size: 40, color: '#D4AF37', delay: '5s',   duration: '25s', opacity: 0.45 },
	{ left: '50%', top: '10%', size: 30, color: '#D4AF37', delay: '10s',  duration: '19s', opacity: 0.3 },
	{ left: '92%', top: '50%', size: 25, color: '#87CEEB', delay: '2s',   duration: '21s', opacity: 0.4 },
	{ left: '5%',  top: '80%', size: 32, color: '#D4AF37', delay: '8s',   duration: '23s', opacity: 0.35 },
	{ left: '60%', top: '85%', size: 20, color: '#87CEEB', delay: '12s',  duration: '17s', opacity: 0.5 },
	{ left: '35%', top: '35%', size: 24, color: '#D4AF37', delay: '6s',   duration: '20s', opacity: 0.4 },
	{ left: '70%', top: '40%', size: 30, color: '#87CEEB', delay: '14s',  duration: '24s', opacity: 0.35 },
	{ left: '20%', top: '90%', size: 26, color: '#D4AF37', delay: '4s',   duration: '16s', opacity: 0.45 },
	// Mariposas grandes cerca del centro para dar contraste al glass del countdown
	{ left: '30%', top: '50%', size: 55, color: '#D4AF37', delay: '1s',   duration: '22s', opacity: 0.6 },
	{ left: '62%', top: '45%', size: 50, color: '#87CEEB', delay: '9s',   duration: '20s', opacity: 0.55 },
	{ left: '45%', top: '55%', size: 45, color: '#D4AF37', delay: '4s',   duration: '24s', opacity: 0.5 },
	{ left: '55%', top: '40%', size: 38, color: '#87CEEB', delay: '11s',  duration: '18s', opacity: 0.5 },
	{ left: '25%', top: '45%', size: 42, color: '#87CEEB', delay: '7s',   duration: '21s', opacity: 0.55 },
	{ left: '72%', top: '55%', size: 48, color: '#D4AF37', delay: '13s',  duration: '19s', opacity: 0.6 },
]
---

<div class="butterflies-container" aria-hidden="true">
	{butterflies.map((b) => (
		<svg
			class="butterfly"
			viewBox="0 0 100 100"
			xmlns="http://www.w3.org/2000/svg"
			style={`
				left: ${b.left};
				top: ${b.top};
				width: ${b.size}px;
				height: ${b.size}px;
				color: ${b.color};
				opacity: ${b.opacity};
				animation-delay: ${b.delay};
				animation-duration: ${b.duration};
			`}
		>
			<path d="M50 50 C30 20, 10 20, 10 45 C10 60, 30 70, 50 50 Z" fill="currentColor" opacity="0.8" />
			<path d="M50 50 C70 20, 90 20, 90 45 C90 60, 70 70, 50 50 Z" fill="currentColor" opacity="0.8" />
			<path d="M50 50 C35 60, 20 80, 25 90 C30 95, 45 80, 50 50 Z" fill="currentColor" opacity="0.6" />
			<path d="M50 50 C65 60, 80 80, 75 90 C70 95, 55 80, 50 50 Z" fill="currentColor" opacity="0.6" />
		</svg>
	))}
</div>

<style>
	.butterflies-container {
		position: absolute;
		inset: 0;
		overflow: hidden;
		pointer-events: none;
		z-index: 1;
	}

	.butterfly {
		position: absolute;
		will-change: transform;
		animation-name: float;
		animation-timing-function: ease-in-out;
		animation-iteration-count: infinite;
	}

	/* Animación de flotado suave: sube/baja + rotación sutil */
	@keyframes float {
		0% {
			transform: translateY(0) rotate(0deg) scale(1);
		}
		25% {
			transform: translateY(-20px) rotate(5deg) scale(1.05);
		}
		50% {
			transform: translateY(-10px) rotate(-3deg) scale(0.98);
		}
		75% {
			transform: translateY(-25px) rotate(4deg) scale(1.03);
		}
		100% {
			transform: translateY(0) rotate(0deg) scale(1);
		}
	}

	/* Respetar preferencia de reducción de movimiento */
	@media (prefers-reduced-motion: reduce) {
		.butterfly {
			animation: none;
		}
	}
</style>
