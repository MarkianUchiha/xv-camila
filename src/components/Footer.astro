---
// Footer: agradecimiento, crédito, copyright y control de música
import MusicToggle from './MusicToggle.tsx'
---

<footer id="footer" class="py-14 pb-24 px-6 text-center" style="background: linear-gradient(180deg, #c99a95 0%, #a88a7e 100%);">
	<p class="font-serif text-lg text-white/80 italic max-w-md mx-auto">
		Te esperamos para compartir este día único
	</p>

	<!-- Estrella separadora 5-puntas -->
	<svg class="w-6 h-6 mx-auto text-gold-100 my-6" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" fill="currentColor">
		<path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
	</svg>

	<p class="font-sans text-xs text-white/40">
		Diseñado by <a href="https://markidev.com" target="_blank" rel="noopener noreferrer" class="text-gold-100 font-medium hover:text-white transition-colors">MarkiDev</a>
	</p>
	<p class="font-sans text-xs text-white/30 mt-1">
		© 2026
	</p>

	<!-- Control de música -->
	<div class="mt-4">
		<MusicToggle client:load />
	</div>
</footer>
