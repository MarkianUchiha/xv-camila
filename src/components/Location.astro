---
// Sección Ubicación: dos cards con mapas embebidos de Google Maps
---

<section id="location" class="py-20 md:py-28 px-6 bg-white">
	<div class="max-w-4xl mx-auto">
		<h2 class="font-serif text-3xl md:text-4xl text-primary-800 text-center mb-12 reveal">
			Ubicación
		</h2>

		<div class="grid grid-cols-1 md:grid-cols-2 gap-6">
			<!-- Ceremonia -->
			<div class="glass-strong overflow-hidden reveal" data-delay="1">
				<div class="aspect-video">
					<iframe
						src="https://maps.google.com/maps?q=Templo+de+Fatima+Durango+Mexico&output=embed"
						class="w-full h-full border-0"
						loading="lazy"
						referrerpolicy="no-referrer-when-downgrade"
						title="Mapa Templo de Fátima"
					></iframe>
				</div>
				<div class="p-5 text-center">
					<h3 class="font-serif text-lg text-primary-800">
						Ceremonia Religiosa
					</h3>
					<p class="font-sans text-sm text-primary-600/70 mt-1">
						Templo de Fátima, Durango
					</p>
					<a
						href="https://maps.google.com/?q=Templo+de+Fatima+Durango+Mexico"
						target="_blank"
						rel="noopener noreferrer"
						class="inline-flex items-center gap-1.5 mt-3 font-display text-xs tracking-widest uppercase text-gold-600 hover:text-gold-700 transition-colors"
					>
						<svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
							<path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z" stroke-linecap="round" stroke-linejoin="round"/>
							<circle cx="12" cy="9" r="2.5"/>
						</svg>
						Ver en Maps
					</a>
				</div>
			</div>

			<!-- Recepción -->
			<div class="glass-strong overflow-hidden reveal" data-delay="2">
				<div class="aspect-video">
					<iframe
						src="https://maps.google.com/maps?q=Centro+de+Convenciones+Holiday+Inn+Durango+Mexico&output=embed"
						class="w-full h-full border-0"
						loading="lazy"
						referrerpolicy="no-referrer-when-downgrade"
						title="Mapa Holiday Inn Durango"
					></iframe>
				</div>
				<div class="p-5 text-center">
					<h3 class="font-serif text-lg text-primary-800">
						Recepción y Cena
					</h3>
					<p class="font-sans text-sm text-primary-600/70 mt-1">
						Centro de Convenciones Holiday Inn, Durango
					</p>
					<a
						href="https://maps.google.com/?q=Centro+de+Convenciones+Holiday+Inn+Durango+Mexico"
						target="_blank"
						rel="noopener noreferrer"
						class="inline-flex items-center gap-1.5 mt-3 font-display text-xs tracking-widest uppercase text-gold-600 hover:text-gold-700 transition-colors"
					>
						<svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
							<path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z" stroke-linecap="round" stroke-linejoin="round"/>
							<circle cx="12" cy="9" r="2.5"/>
						</svg>
						Ver en Maps
					</a>
				</div>
			</div>
		</div>
	</div>
</section>
