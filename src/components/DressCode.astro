---
// Sección Dress Code: card glass con código de vestimenta y restricción de color
---

<section id="dresscode" class="py-20 md:py-28 px-6 bg-white">
	<div class="max-w-sm mx-auto reveal">
		<div class="glass-strong p-8 text-center">
			<!-- Ícono percha -->
			<svg class="w-10 h-10 mx-auto text-gold-500 mb-5" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
				<path d="M12 5a2 2 0 100-4 2 2 0 000 4z" stroke="currentColor" stroke-width="1.5"/>
				<path d="M12 5v1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
				<path d="M3 18l9-7 9 7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
				<path d="M3 18h18v2H3v-2z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
			</svg>

			<h2 class="font-serif text-2xl md:text-3xl text-primary-800 mb-2">
				Dress Code
			</h2>
			<p class="font-display text-xs tracking-[0.3em] text-gold-500 uppercase">
				Formal Elegante
			</p>

			<!-- Notas importantes -->
			<div class="mt-6 space-y-3">
				<div class="rounded-xl px-5 py-4" style="background-color: #EBF5FB;">
					<p class="font-sans text-sm text-primary-700">
						Por favor, evitar el uso de azul claro
						<span class="block text-xs text-primary-500 mt-1 italic">(exclusivo de la quinceañera)</span>
					</p>
				</div>
				<div class="rounded-xl px-5 py-3" style="background-color: #EBF5FB;">
					<p class="font-sans text-sm text-primary-700">Sin niños</p>
				</div>
				<div class="rounded-xl px-5 py-3" style="background-color: #EBF5FB;">
					<p class="font-sans text-sm text-primary-700">Lleva tus tenis <span class="text-xs text-primary-500 italic">(evento sorpresa)</span></p>
				</div>
				<div class="rounded-xl px-5 py-3" style="background-color: #EBF5FB;">
					<p class="font-sans text-sm text-primary-700">Sé puntual</p>
				</div>
			</div>
		</div>
	</div>
</section>
