---
// Sección Galería: grid de fotos con lightbox nativo usando <dialog>
import { Image } from 'astro:assets'

// Importar todas las fotos de la carpeta gallery
import vale1 from '../assets/gallery/Vale_1.jpg'
import vale2 from '../assets/gallery/Vale_2.jpg'
import vale3 from '../assets/gallery/Vale_3.jpg'
import vale4 from '../assets/gallery/VALE_4.jpg'
import vale5 from '../assets/gallery/Vale_5.jpg'
import vale6 from '../assets/gallery/Vale_6.jpg'
import vale7 from '../assets/gallery/Vale_7.jpg'
import vale8 from '../assets/gallery/Vale_8.jpg'
import vale9 from '../assets/gallery/Vale_9.jpg'
import valeFam from '../assets/gallery/Vale_Fam.jpg'
import valeHermano from '../assets/gallery/Vale_Hermano.jpg'
import valeMama from '../assets/gallery/Vale_Mama.jpg'
import valePapa from '../assets/gallery/Vale_Papa.jpg'

const photos = [vale1, vale2, vale3, vale4, vale5, vale6, vale7, vale8, vale9, valeFam, valeHermano, valeMama, valePapa]
---

<section id="gallery" class="py-20 md:py-28 px-4" style="background-color: #F0F8FF;">
	<div class="max-w-5xl mx-auto">
		<h2 class="font-serif text-3xl md:text-4xl text-primary-800 text-center mb-10 reveal">
			Galería
		</h2>

		<!-- Grid de fotos -->
		<div class="columns-2 md:columns-3 lg:columns-4 gap-3 space-y-3">
			{photos.map((photo, i) => (
				<button
					class="gallery-item block w-full rounded-2xl overflow-hidden shadow-md hover:scale-[1.03] hover:shadow-lg transition-all duration-300 break-inside-avoid cursor-pointer border-0 p-0 bg-transparent"
					data-index={i}
					type="button"
				>
					<Image
						src={photo}
						alt={`Foto de Ana Valeria ${i + 1}`}
						width={400}
						quality={80}
						class="w-full h-auto object-cover"
						loading={i < 4 ? 'eager' : 'lazy'}
					/>
				</button>
			))}
		</div>
	</div>

	<!-- Lightbox con <dialog> nativo -->
	<dialog id="lightbox" class="fixed inset-0 w-full h-full max-w-none max-h-none m-0 p-0 bg-black/90 backdrop:bg-transparent z-50">
		<div class="relative w-full h-full flex items-center justify-center p-4">
			<!-- Botón cerrar -->
			<button id="lightbox-close" class="absolute top-4 right-4 z-10 w-10 h-10 flex items-center justify-center rounded-full bg-white/10 text-white hover:bg-white/20 transition-colors cursor-pointer border-0" type="button">
				<svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
					<path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
				</svg>
			</button>

			<!-- Navegación prev -->
			<button id="lightbox-prev" class="absolute left-3 top-1/2 -translate-y-1/2 z-10 w-10 h-10 flex items-center justify-center rounded-full bg-white/10 text-white hover:bg-white/20 transition-colors cursor-pointer border-0" type="button">
				<svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
					<path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/>
				</svg>
			</button>

			<!-- Imagen -->
			<img id="lightbox-img" src="" alt="" class="max-w-full max-h-[85vh] object-contain rounded-lg" />

			<!-- Navegación next -->
			<button id="lightbox-next" class="absolute right-3 top-1/2 -translate-y-1/2 z-10 w-10 h-10 flex items-center justify-center rounded-full bg-white/10 text-white hover:bg-white/20 transition-colors cursor-pointer border-0" type="button">
				<svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
					<path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
				</svg>
			</button>
		</div>
	</dialog>
</section>

<script>
	// Lightbox controlado con vanilla JS y <dialog> nativo
	const dialog = document.getElementById('lightbox') as HTMLDialogElement
	const img = document.getElementById('lightbox-img') as HTMLImageElement
	const items = document.querySelectorAll('.gallery-item')
	let currentIndex = 0

	// Obtener las URLs originales de las imágenes del grid
	const sources: string[] = []
	items.forEach((item) => {
		const imgEl = item.querySelector('img')
		if (imgEl) sources.push(imgEl.src)
	})

	// Mostrar imagen en el lightbox
	function showImage(index: number) {
		currentIndex = ((index % sources.length) + sources.length) % sources.length
		img.src = sources[currentIndex]
		img.alt = `Foto ${currentIndex + 1} de ${sources.length}`
	}

	// Abrir lightbox al hacer click en una foto
	items.forEach((item) => {
		item.addEventListener('click', () => {
			const index = Number(item.getAttribute('data-index'))
			showImage(index)
			dialog.showModal()
		})
	})

	// Cerrar con botón X
	document.getElementById('lightbox-close')?.addEventListener('click', () => dialog.close())

	// Cerrar al hacer click en el fondo oscuro
	dialog.addEventListener('click', (e) => {
		if (e.target === dialog || (e.target as HTMLElement).closest('#lightbox > div') === e.target) {
			dialog.close()
		}
	})

	// Navegación prev/next
	document.getElementById('lightbox-prev')?.addEventListener('click', (e) => {
		e.stopPropagation()
		showImage(currentIndex - 1)
	})
	document.getElementById('lightbox-next')?.addEventListener('click', (e) => {
		e.stopPropagation()
		showImage(currentIndex + 1)
	})

	// Navegación con teclado
	dialog.addEventListener('keydown', (e) => {
		if (e.key === 'ArrowLeft') showImage(currentIndex - 1)
		if (e.key === 'ArrowRight') showImage(currentIndex + 1)
	})
</script>
