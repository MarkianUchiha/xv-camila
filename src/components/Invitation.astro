---
// Sección Invitación: mensaje elegante de la quinceañera con ícono decorativo
---

<section id="invitation" class="py-20 md:py-28 px-6" style="background-color: #FAFCFF;">
	<div class="max-w-xl mx-auto text-center reveal">

		<!-- Ícono decorativo: libro abierto -->
		<svg class="w-12 h-12 mx-auto text-gold-400 mb-6" viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg">
			<path d="M32 14C24 10 14 10 6 14v36c8-4 18-4 26 0 8-4 18-4 26 0V14c-8-4-18-4-26 0z" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
			<path d="M32 14v36" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/>
		</svg>

		<h2 class="font-serif text-3xl md:text-4xl text-primary-800 mb-8">
			Una Noche de Ensueño
		</h2>

		<!-- Mensaje de invitación -->
		<blockquote class="relative font-serif text-base md:text-lg text-gray-600 italic leading-relaxed">
			<span class="text-gold-400 text-4xl leading-none absolute -top-4 -left-2">&ldquo;</span>
			<p class="px-4">
				Hay momentos que se graban para siempre en el corazón. Con la bendición de Dios y el amor de mi familia, te invito a celebrar conmigo esta noche mágica donde mis sueños comienzan a volar. Tu presencia hará de este día un recuerdo inolvidable.
			</p>
			<span class="text-gold-400 text-4xl leading-none">&rdquo;</span>
		</blockquote>

		<!-- Firma -->
		<p class="font-serif text-sm md:text-base text-gold-500 mt-6 text-right pr-4">
			— Con cariño, Ana Valeria
		</p>

		<!-- Mariposa separadora -->
		<svg class="w-8 h-8 mx-auto text-gold-400/50 mt-10" viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg">
			<path d="M50 50 C30 20, 10 20, 10 45 C10 60, 30 70, 50 50 Z" fill="currentColor" opacity="0.8"/>
			<path d="M50 50 C70 20, 90 20, 90 45 C90 60, 70 70, 50 50 Z" fill="currentColor" opacity="0.8"/>
			<path d="M50 50 C35 60, 20 80, 25 90 C30 95, 45 80, 50 50 Z" fill="currentColor" opacity="0.6"/>
			<path d="M50 50 C65 60, 80 80, 75 90 C70 95, 55 80, 50 50 Z" fill="currentColor" opacity="0.6"/>
		</svg>
	</div>
</section>
