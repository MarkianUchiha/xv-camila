---
// Sección Cronograma: timeline vertical con los eventos del día

const events = [
	{
		time: '18:00 hrs',
		title: 'Ceremonia Religiosa',
		place: 'Templo de Fátima',
		// Ícono: iglesia
		icon: `<path d="M12 2L2 12h3v8h14v-8h3L12 2z" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
			   <path d="M9 22v-6h6v6" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
			   <path d="M12 7v3" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
			   <path d="M12 6a1 1 0 100-2 1 1 0 000 2z" fill="currentColor"/>`,
	},
	{
		time: '21:00 hrs',
		title: 'Recepción y Cena',
		place: 'Centro de Convenciones Holiday Inn',
		// Ícono: cubiertos
		icon: `<path d="M3 3v18" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
			   <path d="M3 9c0-3 2-6 5-6s5 3 5 6" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
			   <path d="M8 3v6c0 1.5-1 3-2.5 3" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
			   <path d="M19 3v4c0 2-1.5 3-3 3s-3-1-3-3V3" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
			   <path d="M16 10v11" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>`,
	},
	{
		time: '22:30 hrs',
		title: 'Vals',
		place: '',
		// Ícono: nota musical / baile
		icon: `<circle cx="8" cy="18" r="3" fill="none" stroke="currentColor" stroke-width="1.5"/>
			   <circle cx="18" cy="16" r="3" fill="none" stroke="currentColor" stroke-width="1.5"/>
			   <path d="M11 18V5l10-3v14" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>`,
	},
	{
		time: '23:30 hrs',
		title: 'Evento Sorpresa',
		place: '¡Ponte tus tenis!',
		// Ícono: estrella / sorpresa
		icon: `<path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>`,
	},
]
---

<section id="timeline" class="py-20 md:py-28 px-6" style="background-color: #F0F8FF;">
	<div class="max-w-lg mx-auto">
		<h2 class="font-serif text-3xl md:text-4xl text-primary-800 text-center mb-14 reveal">
			Cronograma
		</h2>

		<!-- Timeline -->
		<div class="relative">
			<!-- Línea vertical -->
			<div class="absolute left-6 top-0 bottom-0 w-[2px] bg-primary-200/60"></div>

			{events.map((event, i) => (
				<div class={`relative flex items-start gap-5 reveal ${i < events.length - 1 ? 'mb-12' : ''}`} data-delay={i + 1}>
					<!-- Nodo: círculo con ícono -->
					<div class="relative z-10 flex-shrink-0 w-12 h-12 rounded-full glass-strong flex items-center justify-center border border-gold-300/40">
						<svg class="w-5 h-5 text-gold-500" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" set:html={event.icon} />
					</div>

					<!-- Contenido -->
					<div class="pt-1">
						<span class="font-display text-xs tracking-[0.2em] text-gold-500 uppercase">
							{event.time}
						</span>
						<h3 class="font-serif text-lg text-gold-600 mt-1">
							{event.title}
						</h3>
						{event.place && (
							<p class={`font-sans text-sm mt-0.5 ${event.title === 'Evento Sorpresa' ? 'text-primary-500 font-medium italic' : 'text-primary-600/70'}`}>
								{event.place}
							</p>
						)}
					</div>
				</div>
			))}
		</div>
	</div>
</section>
