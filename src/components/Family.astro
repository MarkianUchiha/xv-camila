---
// Sección Familia: cards con monograma + mensaje siempre visible (sin fotos)

const members = [
	{
		initials: 'JR',
		name: 'José Luis\nRoacho Corral',
		role: 'Papá',
		message: 'Te amo con mi corazón y deseo que cada sueño tuyo se haga realidad. Tus 15 años marcan una etapa hermosa; disfrútala, sonríe, sé agradecida y nunca dejes de brillar.',
	},
	{
		initials: 'RA',
		name: 'Reyna Ascencio\nPedro',
		role: 'Mamá',
		message: 'Mi niña hermosa, sabes que siempre estaré para ti, oraré todos los días para que seas feliz, espero que cumplas todas tus metas y que siempre cuentes con la bendición de Dios. Tu familia te ama, mi preciosa Quinceañera, nunca lo olvides. Me siento orgullosa de ti.',
	},
]
---

<section id="family" class="py-20 md:py-28 px-6 bg-white">
	<div class="max-w-4xl mx-auto text-center">
		<div class="reveal">
			<h2 class="font-serif text-3xl md:text-4xl text-primary-800 mb-3">
				Con Amor, mi Familia
			</h2>
			<p class="font-display text-xs tracking-[0.3em] text-gold-500 uppercase mb-12">
				Quienes hacen posible este sueño
			</p>
		</div>

		<!-- Padres -->
		<p class="font-display text-[11px] tracking-[0.3em] text-gold-500 uppercase mb-6">
			Mis Padres
		</p>
		<div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
			{members.map((m, i) => (
				<div class="glass-strong p-8 reveal flex flex-col items-center" data-delay={i + 1}>
					<!-- Monograma: círculo con iniciales en script -->
					<div class="w-20 h-20 rounded-full flex items-center justify-center border-2 border-gold-300 mb-5" style="background-color: #fbf5f2;">
						<span class="font-script text-5xl text-gold-700 leading-none -translate-y-1">
							{m.initials}
						</span>
					</div>

					<!-- Nombre -->
					<p class="font-serif text-sm md:text-base text-primary-800 leading-snug" set:html={m.name.replace('\n', '<br/>')} />

					<!-- Rol -->
					<span class="font-display text-[10px] tracking-[0.25em] text-gold-500 uppercase mt-2 mb-4">
						{m.role}
					</span>

					<!-- Divider dorado -->
					<div class="w-10 h-px bg-gold-400/50 mb-4"></div>

					<!-- Mensaje personal -->
					<p class="font-serif text-sm text-primary-700 italic leading-relaxed">
						"{m.message}"
					</p>

					<!-- Estrella decorativa -->
					<svg class="w-5 h-5 text-gold-400/50 mt-5" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" fill="currentColor">
						<path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
					</svg>
				</div>
			))}
		</div>

	</div>
</section>
