---
// Sección Hero: nombre, subtítulo, countdown y estrellas glitter emergentes
import Stars from './Stars.astro'
import Countdown from './Countdown.tsx'
---

<section
	id="hero"
	class="relative min-h-screen flex flex-col items-center justify-center overflow-hidden"
	style="min-height: 100svh;"
>
	<!-- Fondo: dusty rose sólido de la paleta Blush & Gold Luxe -->
	<div
		class="absolute inset-0 -z-10"
		style="background-color: #F5DDD9;"
	>
	</div>

	<!-- Estrellas glitter que emergen del centro -->
	<Stars />

	<!-- Contenido central -->
	<div class="relative z-10 text-center px-6">
		<p class="font-display text-xs md:text-sm tracking-[0.35em] text-gold-500 uppercase mb-4">
			Mis Quince Años
		</p>

		<h1 class="font-script text-7xl sm:text-8xl md:text-9xl text-primary-800 leading-none">
			Camila Isabella
		</h1>

		<p class="font-sans text-sm md:text-base text-primary-700 mt-3">
			18 de Junio de 2026
		</p>

		<!-- Countdown -->
		<div class="mt-10">
			<Countdown client:load />
		</div>
	</div>

	<!-- Indicador de scroll -->
	<div class="absolute bottom-8 z-10 flex flex-col items-center gap-2 animate-bounce">
		<span class="text-xs font-display tracking-widest text-primary-700/80 uppercase">
			Desliza
		</span>
		<svg
			class="w-5 h-5 text-primary-700/60"
			fill="none"
			stroke="currentColor"
			stroke-width="2"
			viewBox="0 0 24 24"
		>
			<path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
		</svg>
	</div>
</section>
